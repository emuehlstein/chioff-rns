# chioff-rns consent allowlist
# Nodes listed here opt in to having their FULL Reticulum hash and a friendly
# name shown on the public status page / Network Visualizer, even when
# public_mode = true. Everyone else stays anonymized (truncated hash).
#
# Edit this file (e.g. on GitHub) and deploy; it is copied to
# /etc/chioff-consent.config. Format: <full-hex-hash> = <friendly label>
# A prefix (>= 8 hex chars) also matches, but full hashes are recommended.

[consent]
# rns.chicagooffline.com = Chicago Offline Transport
# 0123456789abcdef0123456789abcdef = Home RNS
# fedcba9876543210fedcba9876543210 = Bowmanville RNS
